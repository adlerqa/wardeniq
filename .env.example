# Copy to .env and adjust. `./run.sh` reads this file.

# Signs sessions and encrypts secrets stored in the DB. Change this in production.
APP_SECRET=change-me-in-production

# ---- Auth (passwordless email OTP, always on — no bypass flag) ----
ADMIN_EMAIL=              # first admin on startup; blank = first person to sign in
COOKIE_SECURE=false       # true when serving over HTTPS
SESSION_TTL_SECONDS=604800
OTP_TTL_SECONDS=600
# SMTP for OTP emails is configured in-app (Configuration → Email). Until it is,
# the first admin's one-time code is printed to the server log so they can sign in
# and set email up. Once SMTP is configured, codes are emailed and never logged.

# ---- LLM / embeddings (Ollama by default; hosted providers incl. AWS Bedrock are
# configured in-app under Configuration → LLM / Embeddings, not here) ----
GEN_MODEL=qwen2.5:3b
EMBED_MODEL=nomic-embed-text
EMBED_DIM=768
GEN_TOTAL=16

# ---- GitHub (optional; also settable in-app) ----
GITHUB_TOKEN=
POLL_INTERVAL_SECONDS=120
WEBHOOK_SECRET=

# ---- Database ----
DB_NAME=wardeniq
# MONGO_URI — set here to bring your own DB (Atlas, or self-managed with mongot);
# leave blank to use the bundled MongoDB. Can also be set from Configuration →
# Database in-app, which writes it back into this file.
# MONGO_URI=mongodb+srv://USER:PASS@your-cluster.mongodb.net/?retryWrites=true&w=majority

# ---- Bundled images (only used with docker-compose.mongodb.yml) ----
MONGO_IMAGE=mongodb/mongodb-community-server:8.3-ubi9
MONGOT_IMAGE=mongodb/mongodb-community-search:0.65.1

# ---- App image (a client with no source points this at your published image) ----
# APP_IMAGE=your-registry/wardeniq:1.0

# ---- Ollama (also settable in-app) ----
# OLLAMA_URL pins and locks the endpoint in the UI; leave blank to keep it editable.
# The fallback (OLLAMA_URL_BUNDLED) is set by the installer per mode: the bundled
# container, or your own host Ollama (http://host.docker.internal:11434) for the
# app-only flow. Only set these by hand if you skip the installer.
# OLLAMA_URL=http://host.docker.internal:11434

# ---- SMTP (optional). In-app Configuration → Email takes precedence once set; this
# is the FALLBACK — it bootstraps OTP email for the very first admin login (before you
# can sign in to configure it in-app) and covers an APP_SECRET rotation. ----
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
# SMTP_TLS=true
# SMTP_SSL=false
